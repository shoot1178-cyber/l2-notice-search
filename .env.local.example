# GitHub 저장소 설정 (공지 파일이 있는 저장소)
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=l2-notice-search

# GitHub Personal Access Token (private repo인 경우 필요, public이면 생략 가능)
# https://github.com/settings/tokens 에서 생성
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (AI 공지 검색 기능에 필요)
# https://console.anthropic.com/settings/keys 에서 생성
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
